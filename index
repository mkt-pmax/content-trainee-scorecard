<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Candidate Scorecard — Marketing Trainee (Content)</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;1,400&display=swap');

  :root {
    --blue: #0000FF;
    --orange: #FF6000;
    --azure: #0080FF;
    --navy: #050A30;
    --ink: #0A0A14;
    --white: #ffffff;
    --off: #F5F5F8;
    --border: #E4E4EA;
    --muted: #8888A0;
    --body: #2A2A3A;
    --green: #0D6E52;
    --green-bg: #E2F4EE;
    --amber: #7A4A08;
    --amber-bg: #FBF0DC;
    --red: #922828;
    --red-bg: #FAEBEB;
    --track: #E4E4EA;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Archivo', 'Helvetica Neue', sans-serif;
    background: var(--off);
    color: var(--body);
    font-size: 13.5px;
    line-height: 1.65;
  }

  /* ── HEADER ── */
  .header {
    background: var(--navy);
    padding: 36px 56px 28px;
    border-bottom: 2.5px solid var(--orange);
  }
  .header-eye {
    font-size: 10.5px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--azure); margin-bottom: 8px;
  }
  .header h1 { font-size: 23px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
  .header-sub { font-size: 12px; color: rgba(255,255,255,0.38); }

  /* ── WRAP ── */
  .wrap { max-width: 1020px; padding: 40px 56px 100px; }

  /* ── SECTION LABEL ── */
  .sec-label {
    font-size: 10.5px; font-weight: 600; letter-spacing: 0.13em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
    padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }

  /* ── SCORECARD GRID ── */
  .scorecard {
    display: grid;
    grid-template-columns: 180px repeat(3, 1fr);
    gap: 0;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }

  .sc-head {
    padding: 14px 18px;
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--muted);
    background: var(--off);
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }
  .sc-head:last-child { border-right: none; }
  .sc-head.cand { text-align: center; }
  .sc-head .cand-name { font-size: 13px; font-weight: 600; color: var(--ink); text-transform: none; letter-spacing: 0; display: block; margin-bottom: 2px; }
  .sc-head .cand-tag { font-size: 10px; font-weight: 500; text-transform: none; letter-spacing: 0; }

  .sc-row-label {
    padding: 14px 18px;
    font-size: 12.5px; font-weight: 500; color: var(--ink);
    background: var(--off);
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    display: flex; align-items: center;
  }
  .sc-row-label:last-child { border-bottom: none; }

  .sc-cell {
    padding: 12px 18px;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    vertical-align: middle;
  }
  .sc-cell:last-child { border-right: none; }

  /* score bar */
  .bar-wrap { display: flex; align-items: center; gap: 8px; }
  .bar-track { flex: 1; height: 5px; background: var(--track); border-radius: 3px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
  .fill-blue { background: var(--blue); }
  .fill-orange { background: var(--orange); }
  .fill-azure { background: var(--azure); }
  .bar-num { font-size: 11.5px; font-weight: 600; color: var(--ink); min-width: 28px; text-align: right; }

  /* delta badge */
  .delta {
    font-size: 10px; font-weight: 600; padding: 1px 5px; border-radius: 4px; margin-left: 4px; vertical-align: middle;
  }
  .d-up { background: var(--green-bg); color: var(--green); }
  .d-dn { background: var(--red-bg); color: var(--red); }
  .d-eq { background: var(--border); color: var(--muted); }

  .sc-note { font-size: 11.5px; color: var(--muted); margin-top: 3px; }

  /* tag chips */
  .chip { display: inline-block; font-size: 10.5px; font-weight: 500; padding: 2px 7px; border-radius: 10px; margin: 1px 2px; }
  .chip-g { background: var(--green-bg); color: var(--green); }
  .chip-a { background: var(--amber-bg); color: var(--amber); }
  .chip-r { background: var(--red-bg); color: var(--red); }

  /* ── DIMENSION TABLE ── */
  .dim-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 32px;
  }
  .dim-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .dim-card-head {
    padding: 12px 16px 10px;
    border-bottom: 1px solid var(--border);
  }
  .dim-card-head .person { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
  .dim-card-head .verdict-chip { font-size: 10.5px; font-weight: 500; padding: 2px 8px; border-radius: 10px; }
  .dim-card-body { padding: 12px 16px; }
  .dim-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 5px 0; border-bottom: 1px solid var(--border); font-size: 12px; gap: 8px; }
  .dim-row:last-child { border-bottom: none; }
  .dim-label { color: var(--muted); flex-shrink: 0; }
  .dim-val { font-weight: 500; color: var(--ink); text-align: right; font-size: 11.5px; }

  /* ── BEFORE / AFTER ── */
  .before-after {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }
  .ba-head {
    display: grid; grid-template-columns: 160px 1fr 1fr;
    background: var(--off);
    border-bottom: 1px solid var(--border);
  }
  .ba-head-cell {
    padding: 11px 18px; font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted);
    border-right: 1px solid var(--border);
  }
  .ba-head-cell:last-child { border-right: none; }
  .ba-row { display: grid; grid-template-columns: 160px 1fr 1fr; border-bottom: 1px solid var(--border); }
  .ba-row:last-child { border-bottom: none; }
  .ba-cell { padding: 12px 18px; font-size: 12.5px; border-right: 1px solid var(--border); color: var(--body); vertical-align: top; }
  .ba-cell:last-child { border-right: none; }
  .ba-cell.person { font-weight: 600; color: var(--ink); background: var(--off); display: flex; align-items: flex-start; padding-top: 14px; }
  .arrow { color: var(--azure); font-weight: 600; margin: 0 4px; }

  /* ── DECISION ── */
  .decision-banner {
    background: var(--navy);
    border-radius: 12px;
    padding: 28px 32px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: center;
    margin-bottom: 14px;
  }
  .dec-label { font-size: 10.5px; font-weight: 600; letter-spacing: 0.13em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 6px; }
  .dec-name { font-size: 24px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
  .dec-sub { font-size: 12px; color: rgba(255,255,255,0.45); }
  .dec-badge { background: var(--green-bg); color: var(--green); font-size: 12.5px; font-weight: 600; padding: 8px 20px; border-radius: 20px; white-space: nowrap; }

  .reason-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .reason-card { background: var(--white); border: 1px solid var(--border); border-radius: 10px; padding: 16px 20px; }
  .reason-card h4 { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.09em; color: var(--muted); margin-bottom: 10px; }
  .reason-card ul { list-style: none; }
  .reason-card ul li { font-size: 12.5px; color: var(--body); padding: 4px 0 4px 16px; position: relative; border-bottom: 1px solid var(--border); line-height: 1.5; }
  .reason-card ul li:last-child { border-bottom: none; }
  .reason-card ul li::before { position: absolute; left: 0; font-weight: 700; }
  .pro li::before { content: '+'; color: var(--green); }
  .con li::before { content: '–'; color: var(--red); }
  .watch li::before { content: '→'; color: var(--amber); }

  .footer-note {
    background: var(--amber-bg); border-radius: 8px; padding: 14px 18px;
    font-size: 12.5px; color: var(--amber); line-height: 1.65; margin-top: 14px;
  }

  .spacer { height: 32px; }

  @media (max-width: 700px) {
    .wrap { padding: 24px 20px 60px; }
    .header { padding: 28px 24px 20px; }
    .dim-grid, .reason-grid { grid-template-columns: 1fr; }
    .scorecard, .before-after { font-size: 12px; }
    .decision-banner { grid-template-columns: 1fr; }
    .ba-head, .ba-row { grid-template-columns: 120px 1fr 1fr; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="header-eye">PMAX Marketing Team · Tháng 6/2026</div>
